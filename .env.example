# ===== Shared =====
NODE_ENV=development

# ===== Database (local via docker compose) =====
POSTGRES_USER=skillforge
POSTGRES_PASSWORD=skillforge_dev_password
POSTGRES_DB=skillforge
POSTGRES_PORT=5432

# Used by API (Prisma)
DATABASE_URL=postgresql://skillforge:skillforge_dev_password@localhost:5432/skillforge?schema=public

# ===== API =====
API_PORT=3200
API_BASE_URL=http://localhost:3200

JWT_ACCESS_SECRET=change_me_access_secret_32+chars
JWT_REFRESH_SECRET=change_me_refresh_secret_32+chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

PASSWORD_PEPPER=change_me_optional_pepper

# CORS
WEB_ORIGIN=http://localhost:3100
WEB_ORIGINS=

# Proxy / cookies (production deployment)
TRUST_PROXY=0
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# ===== AI Provider (OpenAI compatible) =====
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace_me
AI_MODEL=gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=800

# ===== Web =====
WEB_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://localhost:3200
